{% extends "skeleton.jinja" %}

{% block title %}{{ query }} - Search{% endblock %}

{% block content %}
    <div class="city-search">
        <label for="city-search-input" class="city-search__label">Search for a city</label>
        <div class="city-search__field">
            <i class="fa-solid fa-magnifying-glass city-search__icon"
               aria-hidden="true"></i>
            <form action="{{ url_for('search') }}"
                  method="get"
                  class="city-search__form">
                <input id="city-search-input"
                       class="city-search__input"
                       type="search"
                       name="q"
                       value="{{ query }}"
                       placeholder="Amsterdam, London, New York…"
                       autocomplete="off"
                       aria-autocomplete="list"
                       aria-controls="city-search-results"
                       hx-get="{{ url_for('search') }}"
                       hx-trigger="input changed delay:300ms"
                       hx-target="#city-search-results"
                       hx-indicator="#city-search-spinner" />
            </form>
            <span id="city-search-spinner"
                  class="city-search__spinner htmx-indicator"
                  aria-hidden="true"></span>
        </div>
        <div id="city-search-results" class="city-search__dropdown" role="listbox"></div>
    </div>

    <div class="search-results">
        {% if query %}
            {% if places %}
                <p class="search-results__count">{{ places|length }} result{{ 's' if places|length != 1 }}</p>
                <ul class="search-results__list">
                    {% for place in places %}
                        <li>
                            <a href="{{ url_for('weather', place_id=place.place_id) }}"
                               class="search-results__result">
                                <span class="search-results__result-name">{{ place.name }}</span>
                                <span class="search-results__result-meta{% if place.is_direct %} search-results__result-meta--direct{% endif %}">
                                    {%- if place.is_direct -%}
                                        <i class="fa-solid fa-location-dot" aria-hidden="true"></i> Coordinates
                                    {%- elif place.state -%}
                                        {{ place.state }}, {{ place.country }}
                                    {%- else -%}
                                        {{ place.country }}
                                    {%- endif -%}
                                </span>
                            </a>
                        </li>
                    {% endfor %}
                </ul>
            {% else %}
                <p class="search-results__empty">No results for "{{ query }}"</p>
            {% endif %}
        {% endif %}
    </div>
{% endblock %}
