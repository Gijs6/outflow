{% if places %}
    <ul class="search-dropdown" role="listbox" aria-label="Search results">
        {% for place in places %}
            <li class="search-dropdown__item" role="option">
                <a href="{{ url_for('weather', place_id=place.place_id) }}"
                   class="search-dropdown__result">
                    <span class="search-dropdown__result-name">{{ place.name }}</span>
                    <span class="search-dropdown__result-meta{% if place.is_direct %} search-dropdown__result-meta--direct{% endif %}">
                        {%- if place.is_direct -%}
                            <i class="fa-solid fa-location-dot" aria-hidden="true"></i> Coordinates
                        {%- elif place.state -%}
                            {{ place.state }}, {{ place.country }}
                        {%- else -%}
                            {{ place.country }}
                        {%- endif -%}
                    </span>
                </a>
            </li>
        {% endfor %}
    </ul>
{% else %}
    <p class="search-dropdown__empty">No results for "{{ query }}"</p>
{% endif %}
